CFLAGS := -I. -I./libjpeg -I./zlib -I./libjpeg/simd -I./libjpeg/simd/arm -c -Wall -std=c99 -fPIC -Winline -O2 -D_FILE_OFFSET_BITS=64 -DWXPNG_EXPORTS -fvisibility=hidden 

CPPFLAGS := -I. -I./libjpeg -I./zlib -I./libjpeg/simd -I./libjpeg/simd/arm -c -Wall -std=c++14 -fPIC -Winline -O2 -D_FILE_OFFSET_BITS=64 -DWXPNG_EXPORTS -fvisibility=hidden -fexceptions -frtti 

DYLIB_LIB := WX_Image.so

DEPEND_LIB := -lz -lm -lpthread -ldl -lstdc++

CFLAGS += -DNEON_INTRINSICS -DPIC -D__ARM_NEON__ -DDEFAULT_NEON_INTRINSICS 
CFLAGS += -DHAVE_VLD1_S16_X3 -DHAVE_VLD1_U16_X2 -DHAVE_VLD1Q_U8_X4
CPPFLAGS += -DNEON_INTRINSICS -DPIC -D__ARM_NEON__ -DDEFAULT_NEON_INTRINSICS
CPPFLAGS += -DHAVE_VLD1_S16_X3 -DHAVE_VLD1_U16_X2 -DHAVE_VLD1Q_U8_X4

%.o: %.asm
	$(AS) $(ASFLAGS) -o $@ $< 

all:$(OBJS) $(OBJSASM)
	$(CC) -shared -o $(DYLIB_LIB) $(OBJS) $(OBJSASM) $(DEPEND_LIB) -fvisibility=hidden
	$(STRIP) $(DYLIB_LIB) 
	$(CC) -o test.out test.cpp -L./ -lWX_Image.so -lstdc++
			
install: all
	mkdir -p $(PREFIX)/lib
	mkdir -p $(PREFIX)/include
	cp -f $(EXPORT_STATIC_LIB) $(PREFIX)/lib
	cp -f bzlib.h $(PREFIX)/include
		
clean: 
	$(RM) $(OBJS) $(OBJSASM) $(DYLIB_LIB) 

