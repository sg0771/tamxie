CFLAGS += -DLINUX -I. -I./libjpeg -I./zlib -c -Wall -std=c99 -fPIC -Winline -O2 -D_FILE_OFFSET_BITS=64 -DWXPNG_EXPORTS -mavx -msse2 -msse4.1 -mpclmul -fvisibility=hidden
CPPFLAGS += -DLINUX -I. -I./libjpeg -I./zlib -c -Wall -std=c++14 -fPIC -Winline -O2 -D_FILE_OFFSET_BITS=64 -DWXPNG_EXPORTS -mavx -msse2 -msse4.1 -mpclmul -fvisibility=hidden
CXXFLAGS += -DLINUX -I. -I./libjpeg -I./zlib -c -Wall -std=c++14 -fPIC -Winline -O2 -D_FILE_OFFSET_BITS=64 -DWXPNG_EXPORTS -mavx -msse2 -msse4.1 -mpclmul -fvisibility=hidden

ASFLAGS := -f elf64 -D__x86_64__ -DELF -DPIC -I./libjpeg/simd/nasm/ -I./libjpeg/simd/x86_64/ 
DYLIB_LIB := WX_Image.so
DEPEND_LIB := -pthread -lm -ldl -lstdc++

AS=yasm
CC=gcc
AR=ar rcs
RANLIB=ranlib
STRIP=strip
RM=rm -rf

%.o: %.asm
	$(AS) $(ASFLAGS) -o $@ $< 

%.o: %.c
	$(CC) $(CFLAGS) -o $@ $< 

%.o: %.cc
	$(CC) $(CPPFLAGS) -o $@ $< 

%.o: %.cpp WXImageBase.h WXImage.h
	$(CC) $(CPPFLAGS) -o $@ $< 

all:$(OBJS) 
	$(CC) -fvisibility=hidden -shared -o $(DYLIB_LIB) $(OBJS) $(DEPEND_LIB) 
	$(STRIP) $(DYLIB_LIB) 
	$(CC) -o test.out test.cpp $(OBJS) $(OBJSASM) $(DEPEND_LIB) 
	#$(RM) $(OBJS) 	$(DYLIB_LIB) 
	 	
install: all
	mkdir -p $(PREFIX)/lib
	mkdir -p $(PREFIX)/include
	cp -f $(DYLIB_LIB) $(PREFIX)/lib
		
clean: 
	$(RM) $(OBJS) 	$(DYLIB_LIB) 	

