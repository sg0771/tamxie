<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    tools:context="com.wh2007.media.MainActivity" >

        <Button
        android:id="@+id/button1"
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:layout_x="0dp"
        android:layout_y="0dp"
        android:onClick="onStartRec"
        android:text="Start Recoder" />
         
        <Button
        android:id="@+id/button2"
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:layout_x="150dp"
        android:layout_y="0dp"
        android:onClick="onStopRec"
        android:text="Stop Recoder" />
        
        <Button
        android:id="@+id/button3"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:layout_marginTop="23dp"
        android:layout_x="0dp"
        android:layout_y="60dp"
        android:onClick="onStartPlay"
        android:text="Start Play" />
               
        <Button
        android:id="@+id/button4"
        android:layout_width="120dp"
        android:layout_height="60dp"
        android:layout_x="120dp"
        android:layout_y="60dp"
        android:onClick="onStopPlay"
        android:text="Stop Play" />
        
        <Button
        android:id="@+id/button5"
        android:layout_width="80dp"
        android:layout_height="60dp"
        android:layout_x="240dp"
        android:layout_y="60dp"
        android:onClick="onSpeak"
        android:text="扬声器" />

       <SurfaceView
        android:id="@+id/SV1"
        android:layout_width="72dp"
        android:layout_height="100dp"
        android:layout_x="0dp"
        android:layout_y="120dp" />
        
    <SurfaceView
        android:id="@+id/SV2"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_x="75dp"
        android:layout_y="120dp" />
    
     <SurfaceView
        android:id="@+id/SV3"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:layout_x="150dp"
        android:layout_y="120dp" />
     
     


     <Button
         android:id="@+id/button6"
         android:layout_width="70dp"
         android:layout_height="40dp"
         android:layout_x="0dp"
         android:layout_y="220dp"
         android:onClick="onStartVideo320"
         android:text="320P" />
     
      <Button
         android:id="@+id/button7"
         android:layout_width="70dp"
         android:layout_height="40dp"
         android:layout_x="70dp"
         android:layout_y="220dp"
         android:onClick="onStartVideo640"
         android:text="640P" />
          
       <Button
         android:id="@+id/button8"
         android:layout_width="70dp"
         android:layout_height="40dp"
         android:layout_x="140dp"
         android:layout_y="220dp"
         android:onClick="onStartVideo720"
         android:text="720P" />

     <Button
         android:id="@+id/button9"
         android:layout_width="70dp"
         android:layout_height="40dp"
         android:layout_x="210dp"
         android:layout_y="220dp"
         android:onClick="onStopVideo"
         android:text="Stop" />

        <Button
            android:id="@+id/button10"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_x="30dp"
            android:layout_y="278dp"
            android:onClick="MJ"
            android:text="MJ" />
        
        <Button
            android:id="@+id/button11"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_x="110dp"
            android:layout_y="278dp"
            android:onClick="MJ2"
            android:text="MJ2" />
        
           <Button
            android:id="@+id/button12"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_x="190dp"
            android:layout_y="278dp"
            android:onClick="MJ3"
            android:text="MJ3" />

</AbsoluteLayout>