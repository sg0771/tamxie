LOCAL_PATH:= $(call my-dir)
include $(CLEAR_VARS)


LOCAL_MODULE    := WXImage


LOCAL_C_INCLUDES += $(LOCAL_PATH) 
LOCAL_C_INCLUDES += $(LOCAL_PATH)/../libjpeg
LOCAL_C_INCLUDES += $(LOCAL_PATH)/../libjpeg/simd
LOCAL_C_INCLUDES += $(LOCAL_PATH)/../libjpeg/simd/arm
LOCAL_C_INCLUDES += $(LOCAL_PATH)/../zlib

ifeq ($(TARGET_ARCH_ABI), arm64-v8a)
LOCAL_CFLAGS     += -DNEON_INTRINSICS  -DPIC -mfloat-abi=softfp -D__ARM_NEON__  -DDEFAULT_NEON_INTRINSICS
LOCAL_CFLAGS     += -DHAVE_VLD1_S16_X3 -DHAVE_VLD1_U16_X2 -DHAVE_VLD1Q_U8_X4
else
LOCAL_CFLAGS     += -DNEON_INTRINSICS  -DPIC -mfloat-abi=softfp -D__ARM_NEON__  -DDEFAULT_NEON_INTRINSICS
LOCAL_CFLAGS     += -mfpu=neon
endif


LOCAL_ASMFLAGS   += -fPIC	-DPIC  -DNEON_INTRINSICS -mfloat-abi=softfp -D__ARM_NEON__  -DDEFAULT_NEON_INTRINSICS

LOCAL_LDLIBS     += -lm -llog -landroid -lm -pthread -Os

